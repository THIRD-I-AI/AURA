{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git branch*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git fetch*)",
      "Bash(python -m pytest*)",
      "Bash(ruff check*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(npm ci)",
      "Bash(npm run*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "awk '/^## DIGEST/{f=1;next} /^## /{f=0} f' docs/workbench/STATE.md 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Loading workbench state digest"
          }
        ]
      }
    ]
  }
}
