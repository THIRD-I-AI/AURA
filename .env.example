# ==================== AURA Environment Variables ====================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── AI / LLM ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_API_KEY=your-google-api-key-here          # Fallback for Gemini

# ── MCP (optional) ────────────────────────────────────────────────────
MCP_API_KEY=

# ── Service URLs (only needed when NOT using orchestrator.py) ─────────
# orchestrator.py launches all services on these ports automatically.
# Override when running in Docker or split-host setups.
AURA_GATEWAY_URL=http://localhost:8000
AURA_CODEGEN_URL=http://localhost:8001
AURA_CONNECTORS_URL=http://localhost:8002
AURA_SANDBOX_URL=http://localhost:8003
AURA_SCHEDULER_URL=http://localhost:8004
AURA_INSIGHTS_URL=http://localhost:8005
ORCHESTRATION_SERVICE_URL=http://localhost:8006/v1/orchestrations/query

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./aura.db
DATABASE_SERVICE_URL=http://localhost:8002
SCHEDULER_DATABASE_URL=sqlite+aiosqlite:///data/scheduler.db

# ── Agent Framework ───────────────────────────────────────────────────
AURA_TOOL_TIMEOUT=60
CODEGEN_MODEL=gemini-2.5-flash
GENERATOR_MODEL=gemini-2.5-flash

# ── Scheduler ─────────────────────────────────────────────────────────
SCHEDULER_PORT=8004
SCHEDULER_CHECK_INTERVAL=60

# ── CORS ──────────────────────────────────────────────────────────────
ORCHESTRATION_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Notifications (scheduler job failure alerts) ──────────────────────
# Email — leave SMTP_HOST blank to disable email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=
ALERT_TO_EMAILS=admin@example.com,ops@example.com

# Slack — leave blank to disable
SLACK_WEBHOOK_URL=

# Generic webhook — leave blank to disable
ALERT_WEBHOOK_URL=

# ── Misc ──────────────────────────────────────────────────────────────
PYTHONPATH=.
EXECUTION_TIMEOUT_SECONDS=15
