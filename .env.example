# ==================== AURA Environment Variables ====================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── AI / LLM ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_API_KEY=your-google-api-key-here          # Fallback for Gemini

# ── MCP (optional) ────────────────────────────────────────────────────
MCP_API_KEY=

# ── Crypto / compliance keys ──────────────────────────────────────────
# PII egress tokenization (S34d). When set, client-facing audit findings
# show deterministic per-(tenant,field,value) tokens (PII-xxxxxxxxxxxx)
# so auditors can correlate entities without raw PII. When unset, AURA
# falls back to blanket [REDACTED]. Use a long random secret; rotating
# it changes every token. Independent of the ED25519 signing key.
AURA_PII_TOKEN_KEY=
# Persistent ED25519 report-signing key (hex). If unset, a key is
# generated and persisted under data/keys/ on first signature.
AURA_SIGNING_PRIVATE_KEY_HEX=

# ── Service URLs (only needed when NOT using orchestrator.py) ─────────
# orchestrator.py launches all services on these ports automatically.
# Override when running in Docker or split-host setups.
AURA_GATEWAY_URL=http://localhost:8000
AURA_CODEGEN_URL=http://localhost:8001
AURA_CONNECTORS_URL=http://localhost:8002
AURA_SANDBOX_URL=http://localhost:8003
AURA_SCHEDULER_URL=http://localhost:8004
AURA_INSIGHTS_URL=http://localhost:8005
ORCHESTRATION_SERVICE_URL=http://localhost:8006/v1/orchestrations/query

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./aura.db
DATABASE_SERVICE_URL=http://localhost:8002
SCHEDULER_DATABASE_URL=sqlite+aiosqlite:///data/scheduler.db

# ── Agent Framework ───────────────────────────────────────────────────
AURA_TOOL_TIMEOUT=60
CODEGEN_MODEL=gemini-2.5-flash
GENERATOR_MODEL=gemini-2.5-flash

# ── Scheduler ─────────────────────────────────────────────────────────
SCHEDULER_PORT=8004
SCHEDULER_CHECK_INTERVAL=60

# ── CORS ──────────────────────────────────────────────────────────────
ORCHESTRATION_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Notifications (scheduler job failure alerts) ──────────────────────
# Email — leave SMTP_HOST blank to disable email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=
ALERT_TO_EMAILS=admin@example.com,ops@example.com

# Slack — leave blank to disable
SLACK_WEBHOOK_URL=

# Generic webhook — leave blank to disable
ALERT_WEBHOOK_URL=

# ── Misc ──────────────────────────────────────────────────────────────
PYTHONPATH=.
EXECUTION_TIMEOUT_SECONDS=15

# ── UASR self-healing layer (port 8009) ───────────────────────────────
# Single-node default is memory + local (no Redis). For >1 replica switch to
# the distributed backend: shared state in Redis + fleet-wide repair admission.
# See docs/DEPLOYMENT.md "UASR self-healing" for the full matrix.
UASR_MAPEK_ENABLED=true
UASR_STATE_BACKEND=memory                 # memory | redis
UASR_REPAIR_BACKEND=local                 # local | distributed | none
# UASR_REDIS_URL=redis://redis:6379/0     # required when either backend is redis/distributed
# UASR_REPAIR_MAX_GLOBAL_CONCURRENT=8     # fleet-wide recovery budget (distributed)
# UASR_REPAIR_MAX_CONCURRENT=4            # per-process recovery cap (local)
