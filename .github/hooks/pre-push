#!/bin/sh
# Pre-push hook: runs tests and type-check before any push.
# Install with: .\scripts\install-hooks.ps1

set -e

BRANCH=$(git rev-parse --abbrev-ref HEAD)

echo "==> pre-push: branch '$BRANCH'"

if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo "ERROR: Direct push to '$BRANCH' is not allowed. Open a PR from a feature branch."
  exit 1
fi

# Detect repo root so we can find the venv regardless of cwd
REPO_ROOT=$(git rev-parse --show-toplevel)

# Run backend tests — prefer make, fall back to venv pytest (Windows)
echo "==> Running backend tests"
if command -v make > /dev/null 2>&1; then
  make test
else
  VENV_PYTEST=""
  for candidate in "$REPO_ROOT/.venv/Scripts/pytest" "$REPO_ROOT/venv/Scripts/pytest" "$REPO_ROOT/.venv/bin/pytest" "$REPO_ROOT/venv/bin/pytest"; do
    if [ -f "$candidate" ]; then
      VENV_PYTEST="$candidate"
      break
    fi
  done
  if [ -n "$VENV_PYTEST" ]; then
    "$VENV_PYTEST" "$REPO_ROOT/aurabackend/tests/" \
      --ignore="$REPO_ROOT/aurabackend/tests/test_operability.py" \
      --ignore="$REPO_ROOT/aurabackend/tests/test_e2e_eval_gate_real.py" \
      --tb=short -q
  else
    echo "WARNING: neither make nor venv pytest found — skipping backend tests"
  fi
fi

# Run frontend type-check — prefer make, fall back to npx tsc (Windows)
echo "==> Running frontend type-check"
if command -v make > /dev/null 2>&1; then
  make frontend-typecheck
else
  # Call the LOCAL tsc binary directly. `npx tsc` hangs forever on a
  # non-interactive "Need to install …? (y)" prompt in the push context,
  # which froze the whole gate. (`|| true` keeps the type-check advisory,
  # as before — pytest above is the blocking check.)
  if [ -x "$REPO_ROOT/frontend/node_modules/.bin/tsc" ]; then
    ( cd "$REPO_ROOT/frontend" && ./node_modules/.bin/tsc --noEmit ) || true
  else
    ( cd "$REPO_ROOT/frontend" && npx --no-install tsc --noEmit 2>&1 ) || true
  fi
  cd "$REPO_ROOT"
fi

echo "==> All checks passed."
