# AURA Frontend — Environment Variables
# Copy to .env and customize as needed. All values have sensible defaults.

# API base URL.
#   DEV (this file -> .env for `npm run dev`): keep the localhost value below.
#     The Vite dev server (:5173) is cross-origin to the gateway (:8000) and
#     has no proxy, so the explicit URL is required.
#   PRODUCTION (built bundle served behind nginx): do NOT set VITE_API_URL in
#     the build environment -- leave it empty. An empty base makes every
#     request relative (/api/v1/...), so the app talks to whatever host served
#     it and the same image deploys to any cloud domain without a rebuild.
#     A localStorage('apiUrl') override still wins at runtime.
VITE_API_URL=http://localhost:8000
VITE_REQUEST_TIMEOUT=30000
VITE_HEALTH_CHECK_INTERVAL=10000
VITE_MAX_UPLOAD_SIZE=104857600
VITE_APP_NAME=AURA Analytics
VITE_APP_VERSION=v1.0
VITE_AI_MODEL_LABEL=Groq llama-3.3-70b (NL → SQL)
VITE_DOCS_URL=https://github.com/THIRD-I-AI/AURA#readme
VITE_WELCOME_MESSAGE=Welcome to AURA Analytics. I'm here to help you analyze your data. Ask me anything about your datasets!
