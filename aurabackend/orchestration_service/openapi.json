{
  "components": {
    "schemas": {
      "AgentResponse": {
        "properties": {
          "confidence": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "description": "Confidence score assigned by critic agent.",
            "title": "Confidence"
          },
          "details": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Details"
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message"
          },
          "final_query": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Final Query"
          },
          "job_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Job Id"
          },
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "title": "AgentResponse",
        "type": "object"
      },
      "ChatRequest": {
        "properties": {
          "context": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": "Schema: sales_table(product_name, total_revenue, sale_date)",
            "description": "Database schema or other context for the query.",
            "title": "Context"
          },
          "prompt": {
            "title": "Prompt",
            "type": "string"
          },
          "session_id": {
            "title": "Session Id",
            "type": "string"
          }
        },
        "required": [
          "session_id",
          "prompt"
        ],
        "title": "ChatRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "MCPHandshakeRequest": {
        "properties": {
          "protocol_version": {
            "default": "1.0",
            "title": "Protocol Version",
            "type": "string"
          },
          "requested_tools": {
            "items": {
              "$ref": "#/components/schemas/ToolDescriptor"
            },
            "title": "Requested Tools",
            "type": "array"
          },
          "session_id": {
            "title": "Session Id",
            "type": "string"
          }
        },
        "required": [
          "session_id"
        ],
        "title": "MCPHandshakeRequest",
        "type": "object"
      },
      "MCPHandshakeResponse": {
        "properties": {
          "accepted": {
            "title": "Accepted",
            "type": "boolean"
          },
          "granted_tools": {
            "items": {
              "$ref": "#/components/schemas/ToolDescriptor"
            },
            "title": "Granted Tools",
            "type": "array"
          },
          "protocol_version": {
            "title": "Protocol Version",
            "type": "string"
          },
          "reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reason"
          },
          "session_id": {
            "title": "Session Id",
            "type": "string"
          }
        },
        "required": [
          "session_id",
          "protocol_version",
          "accepted"
        ],
        "title": "MCPHandshakeResponse",
        "type": "object"
      },
      "ToolDescriptor": {
        "properties": {
          "capabilities": {
            "items": {
              "type": "string"
            },
            "title": "Capabilities",
            "type": "array"
          },
          "description": {
            "title": "Description",
            "type": "string"
          },
          "metadata": {
            "additionalProperties": {
              "type": "string"
            },
            "title": "Metadata",
            "type": "object"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "tool_id": {
            "title": "Tool Id",
            "type": "string"
          }
        },
        "required": [
          "tool_id",
          "name",
          "description"
        ],
        "title": "ToolDescriptor",
        "type": "object"
      },
      "ToolInvocation": {
        "properties": {
          "invocation_id": {
            "title": "Invocation Id",
            "type": "string"
          },
          "payload_json": {
            "title": "Payload Json",
            "type": "string"
          },
          "session_id": {
            "title": "Session Id",
            "type": "string"
          },
          "tool_id": {
            "title": "Tool Id",
            "type": "string"
          }
        },
        "required": [
          "invocation_id",
          "tool_id",
          "session_id",
          "payload_json"
        ],
        "title": "ToolInvocation",
        "type": "object"
      },
      "ToolInvocationResult": {
        "properties": {
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message"
          },
          "invocation_id": {
            "title": "Invocation Id",
            "type": "string"
          },
          "result_json": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Result Json"
          },
          "success": {
            "title": "Success",
            "type": "boolean"
          }
        },
        "required": [
          "invocation_id",
          "success"
        ],
        "title": "ToolInvocationResult",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    },
    "securitySchemes": {
      "APIKeyHeader": {
        "in": "header",
        "name": "x-mcp-api-key",
        "type": "apiKey"
      }
    }
  },
  "info": {
    "description": "Coordinates multi-agent SQL generation and validation",
    "title": "AURA Orchestration Service",
    "version": "2.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "root__get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Root  Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Root"
      }
    },
    "/health": {
      "get": {
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health"
      }
    },
    "/mcp/handshake": {
      "post": {
        "operationId": "_handshake_endpoint_mcp_handshake_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MCPHandshakeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MCPHandshakeResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "summary": " Handshake Endpoint",
        "tags": [
          "mcp"
        ]
      }
    },
    "/mcp/invoke": {
      "post": {
        "operationId": "_invoke_endpoint_mcp_invoke_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ToolInvocation"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ToolInvocationResult"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "summary": " Invoke Endpoint",
        "tags": [
          "mcp"
        ]
      }
    },
    "/v1/orchestrations/query": {
      "post": {
        "operationId": "generate_query_v1_orchestrations_query_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Generate Query"
      }
    }
  }
}
