  "info": {
    "description": "Data Agnostic Researcher \u2014 headless background research over DuckDB analytics lake",
    "title": "AURA DAR Service Service",
    "version": "2.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/dar/daemon/start": {
      "post": {
        "operationId": "daemon_start_dar_daemon_start_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Daemon Start Dar Daemon Start Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Daemon Start"
      }
    },
    "/dar/daemon/status": {
      "get": {
        "description": "Surface daemon liveness \u2014 operators check this after a deploy\nto confirm the background loop actually came up.",
        "operationId": "daemon_status_dar_daemon_status_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Daemon Status Dar Daemon Status Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Daemon Status"
      }
    },
    "/dar/daemon/stop": {
      "post": {
        "operationId": "daemon_stop_dar_daemon_stop_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Daemon Stop Dar Daemon Stop Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Daemon Stop"
      }
    },
    "/dar/insights": {
      "get": {
        "operationId": "list_insights_dar_insights_get",
        "parameters": [
          {
            "in": "query",
            "name": "table",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Table"
            }
          },
          {
            "in": "query",
            "name": "source",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Source"
            }
          },
          {
            "in": "query",
            "name": "finding_type",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Finding Type"
            }
          },
          {
            "in": "query",
            "name": "min_score",
            "required": false,
            "schema": {
              "default": 0.0,
              "maximum": 1.0,
              "minimum": 0.0,
              "title": "Min Score",
              "type": "number"
            }
          },
          {
            "in": "query",
            "name": "anomalies_only",
            "required": false,
            "schema": {
              "default": false,
              "title": "Anomalies Only",
              "type": "boolean"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 50,
              "maximum": 500,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/InsightOut"
                  },
                  "title": "Response List Insights Dar Insights Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Insights"
      }
    },
