# ======================================================================
# AURA BACKEND — Environment Configuration Template
# ======================================================================
# Copy this file to .env and fill in your values.
# The root .env is also loaded (aurabackend/.env takes priority).

# ── General ──────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info
LOG_FILE=                              # e.g. logs/aura.log (leave empty for stdout only)

# ── AI / LLM ────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
CODEGEN_MODEL=gemini-2.5-flash
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3
# OLLAMA_PREFERRED_MODELS=qwen2.5-coder:7b,llama3:8b,mistral:7b,phi3:mini,deepseek-coder-v2:16b
# OLLAMA_HEALTH_TIMEOUT=3
# OPENAI_API_KEY=your-openai-key
# OPENAI_MODEL=gpt-4o-mini
# AURA_DEFAULT_MAX_TOKENS=4096
# AURA_LLM_TIMEOUT=120

# ── Service Ports ───────────────────────────────────────────────────
API_GATEWAY_PORT=8000
CODE_GENERATION_SERVICE_PORT=8001
CONNECTORS_PORT=8002
EXECUTION_SANDBOX_PORT=8003
SCHEDULER_PORT=8004
INSIGHTS_PORT=8005
ORCHESTRATION_SERVICE_PORT=8006
METADATA_STORE_PORT=8007

# ── CORS ────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ── Security / Auth ─────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Primary Database (used by Connector & Sandbox services) ────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aura_vault
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_TYPE=postgresql

# ── AURA Vault (Hybrid Multimodal DB) ──────────────────────────────
AURA_VAULT_BACKEND=postgresql          # or duckdb
AURA_VAULT_HOST=localhost
AURA_VAULT_PORT=5432
AURA_VAULT_DATABASE=aura_vault
AURA_VAULT_USER=postgres
AURA_VAULT_PASSWORD=your-db-password
AURA_VAULT_DUCKDB_PATH=:memory:

# ── Scheduler ───────────────────────────────────────────────────────
SCHEDULER_DATABASE_URL=sqlite+aiosqlite:///data/scheduler.db
SCHEDULER_CHECK_INTERVAL=60

# ── Execution ───────────────────────────────────────────────────────
EXECUTION_TIMEOUT_SECONDS=15

# ── Orchestration ───────────────────────────────────────────────────
TINY_RECURSIVE_MAX_DEPTH=3
TINY_RECURSIVE_CONFIDENCE=0.8

# ── Performance ─────────────────────────────────────────────────────
REQUEST_TIMEOUT=30
MAX_CONCURRENT_REQUESTS=100
DEFAULT_QUERY_LIMIT=1000

# ── Agents ──────────────────────────────────────────────────────────
# AURA_AGENT_TIMEOUT=120
# AURA_MAX_CONCURRENCY=4
# AURA_MEMORY_MAX_ENTRIES=500

# ── Database Pools ──────────────────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Inter-Service URLs (override if services run on different hosts)
# DATABASE_SERVICE_URL=http://localhost:8002
# ORCHESTRATION_SERVICE_URL=http://localhost:8006/v1/orchestrations/query
# EXECUTION_SANDBOX_URL=http://localhost:8003

# ── Feature Flags ───────────────────────────────────────────────────
ENABLE_AI_CHAT=true
ENABLE_DATABASE_CONNECTIVITY=true
ENABLE_VISUALIZATION=true
ENABLE_STRATEGIC_MODE=true

# ── Metadata Admin ──────────────────────────────────────────────────
AURA_ADMIN_EMAIL=
