{
  "components": {
    "schemas": {
      "DatabaseConnectionRequest": {
        "properties": {
          "connection_string": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Custom connection string",
            "title": "Connection String"
          },
          "database": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Database name or file path",
            "title": "Database"
          },
          "host": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Database host",
            "title": "Host"
          },
          "metadata": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "description": "Additional metadata",
            "title": "Metadata"
          },
          "name": {
            "description": "Connection name",
            "title": "Name",
            "type": "string"
          },
          "password": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Password (optional for SQLite)",
            "title": "Password"
          },
          "port": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "description": "Database port",
            "title": "Port"
          },
          "ssl_enabled": {
            "default": false,
            "description": "Enable SSL",
            "title": "Ssl Enabled",
            "type": "boolean"
          },
          "type": {
            "$ref": "#/components/schemas/DatabaseType",
            "description": "Database type"
          },
          "username": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Username (optional for SQLite)",
            "title": "Username"
          }
        },
        "required": [
          "name",
          "type"
        ],
        "title": "DatabaseConnectionRequest",
        "type": "object"
      },
      "DatabaseConnectionResponse": {
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "database": {
            "title": "Database",
            "type": "string"
          },
          "host": {
            "title": "Host",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
          "is_active": {
            "title": "Is Active",
            "type": "boolean"
          },
          "metadata": {
            "additionalProperties": true,
            "title": "Metadata",
            "type": "object"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "port": {
            "title": "Port",
            "type": "integer"
          },
          "ssl_enabled": {
            "title": "Ssl Enabled",
            "type": "boolean"
          },
          "type": {
            "$ref": "#/components/schemas/DatabaseType"
          },
          "updated_at": {
            "format": "date-time",
            "title": "Updated At",
            "type": "string"
          },
          "username": {
            "title": "Username",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "type",
          "host",
          "port",
          "database",
          "username",
          "ssl_enabled",
          "is_active",
          "created_at",
          "updated_at",
          "metadata"
        ],
        "title": "DatabaseConnectionResponse",
        "type": "object"
      },
      "DatabaseType": {
        "enum": [
          "postgresql",
          "mysql",
          "sqlite",
          "mssql",
          "oracle",
          "mongodb",
          "snowflake",
          "bigquery",
          "redshift",
          "databricks",
          "clickhouse",
          "cassandra"
        ],
        "title": "DatabaseType",
        "type": "string"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "QueryRequest": {
        "properties": {
          "connection_id": {
            "description": "Database connection ID",
            "title": "Connection Id",
            "type": "string"
          },
          "limit": {
            "default": 1000,
            "description": "Result limit",
            "title": "Limit",
            "type": "integer"
          },
          "query": {
            "description": "SQL query to execute",
            "title": "Query",
            "type": "string"
          }
        },
        "required": [
          "connection_id",
          "query"
        ],
        "title": "QueryRequest",
        "type": "object"
      },
      "QueryResponse": {
        "properties": {
          "columns": {
            "items": {
              "type": "string"
            },
            "title": "Columns",
            "type": "array"
          },
          "execution_time_ms": {
            "title": "Execution Time Ms",
            "type": "integer"
          },
          "row_count": {
            "title": "Row Count",
            "type": "integer"
          },
          "rows": {
            "items": {
              "items": {},
              "type": "array"
            },
            "title": "Rows",
            "type": "array"
          }
        },
        "required": [
          "columns",
          "rows",
          "row_count",
          "execution_time_ms"
        ],
        "title": "QueryResponse",
        "type": "object"
      },
      "SchemaResponse": {
        "properties": {
          "connection_id": {
            "title": "Connection Id",
            "type": "string"
          },
          "functions": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "title": "Functions",
            "type": "array"
          },
          "last_updated": {
            "format": "date-time",
            "title": "Last Updated",
            "type": "string"
          },
          "procedures": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "title": "Procedures",
            "type": "array"
          },
          "schemas": {
            "items": {
              "type": "string"
            },
            "title": "Schemas",
            "type": "array"
          },
          "tables": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "title": "Tables",
            "type": "array"
          },
          "views": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "title": "Views",
            "type": "array"
          }
        },
        "required": [
          "connection_id",
          "schemas",
          "tables",
          "views",
          "functions",
          "procedures",
          "last_updated"
        ],
        "title": "SchemaResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Enterprise database connectivity and schema management",
