# AURA production environment — copy to .env at the repo root, fill in, keep OUT of git.
# All values marked with <generate> must be set before first boot. Never commit real values.

# ── Postgres ──────────────────────────────────────────────────────────────
DB_USER=aura
DB_PASSWORD=            # strong random password; used by both the db service and every backend
DB_NAME=aura

# ── Signing (audit certificates) ──────────────────────────────────────────
# STABLE ed25519 private key (hex). Generate ONCE, store safely, rotate NEVER.
# A new key invalidates every previously-issued audit certificate.
#   python -c "import os; print(os.urandom(32).hex())"
AURA_SIGNING_PRIVATE_KEY_HEX=

# ── PII tokenization ──────────────────────────────────────────────────────
# Random salt for deterministic PII tokenization. Changing this re-tokens all PII.
#   python -c "import os; print(os.urandom(32).hex())"
AURA_PII_TOKEN_KEY=

# ── JWT session signing ────────────────────────────────────────────────────
# Random secret that signs all session JWTs. Rotate = all sessions invalidated.
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── LLM provider (portable across cloud, customer-hosted, and air-gapped) ──
# AURA talks to any of: a cloud API, any OpenAI-compatible server you host, or a
# fully-local engine (Ollama). Leave everything blank to disable LLM features.
#
# Pick ONE backend explicitly (recommended for prod) — else auto-detect runs in
# AURA_LLM_PROVIDERS order (default: groq,gemini,ollama,openai), first available wins.
# AURA_LLM_PROVIDER=openai          # one of: groq | gemini | ollama | openai
# AURA_LLM_PROVIDERS=groq,gemini,ollama,openai   # auto-detect order (when unpinned)
#
# Mode 1 — cloud API keys (optional; blank disables that provider):
GEMINI_API_KEY=
GROQ_API_KEY=
# OPENAI_API_KEY=
#
# Mode 2 — any OpenAI-compatible endpoint (vLLM, LM Studio, Azure, a customer
# gateway, an on-prem inference box). A self-hosted server usually needs no key.
# Set AURA_LLM_PROVIDER=openai to use it.
# OPENAI_BASE_URL=http://your-inference-host:8001/v1   # (alias: AURA_LLM_BASE_URL)
# OPENAI_MODEL=gpt-4o-mini
#
# Mode 3 — fully local / air-gapped via Ollama (no key, no egress):
# AURA_LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.1

# ── Object storage (uploads) — multi-node scale & on-prem/air-gapped ───────
# Default is local disk (AURA_STORAGE_BACKEND=local). For multi-replica k8s,
# point uploads at S3-compatible storage so the gateway is stateless.
# AURA_STORAGE_BACKEND=s3
# AURA_S3_BUCKET=aura-uploads
# AURA_S3_ENDPOINT_URL=          # set for R2/MinIO/on-prem; leave blank for AWS S3
# AURA_S3_REGION=us-east-1
# AURA_S3_ACCESS_KEY_ID=         # (or AWS_ACCESS_KEY_ID)
# AURA_S3_SECRET_ACCESS_KEY=     # (or AWS_SECRET_ACCESS_KEY)
# AURA_S3_URL_STYLE=path         # path for MinIO/most on-prem; vhost for AWS
# AURA_S3_USE_SSL=true           # false for an http:// MinIO
